# ── Supabase 接続情報 ───────────────────────────────────────────────
# Supabase ダッシュボード > Project Settings > API から取得します。
# このファイルをコピーして `.env.local` を作り、値を埋めてください。
#   cp .env.example .env.local
#
# .env.local は .gitignore 済みなので Git にはコミットされません。

# プロジェクト URL（例: https://xxxxxxxx.supabase.co）
NEXT_PUBLIC_SUPABASE_URL=

# anon（公開）キー: ブラウザからも使う公開鍵。RLS で保護されます。
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role（秘密）キー: サーバー側だけで使用。絶対に公開しないこと。
# 生徒アカウント発行・PDF署名URL発行など管理操作に使います。
SUPABASE_SERVICE_ROLE_KEY=

# サイト表示名（任意）
NEXT_PUBLIC_SITE_NAME=講座コミュニティ

# 生徒に内部メールを割り当てる際のドメイン（Q1=内部メール運用）
# 例: maron-course.jp の場合、生徒「tanaka」→ tanaka@maron-course.jp
NEXT_PUBLIC_MEMBER_EMAIL_DOMAIN=maron-course.jp
